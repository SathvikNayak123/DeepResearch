# --- Agent LLM ---
ANTHROPIC_API_KEY=
# DEEPRESEARCH_LLM_PROVIDER selects the backend; model choice (below) is
# independent of this and can be swapped per provider without touching code:
#   - "anthropic" (default): direct Anthropic Messages API, ANTHROPIC_API_KEY.
#   - "bedrock": same Claude models, billed via AWS instead (SigV4/boto3,
#     AWS_REGION + credential chain, no ANTHROPIC_API_KEY). Needs
#     `pip install "anthropic[bedrock]"` and per-model access granted in the
#     Bedrock console; DEEPRESEARCH_*_MODEL must then be the Bedrock model ID
#     from that console's model catalog, not the direct-API name.
#   - "openrouter": a genuinely different model family, not just a different
#     bill for Claude - OpenAI-compatible chat-completions API, OPENROUTER_API_KEY.
#     DEEPRESEARCH_*_MODEL becomes any OpenRouter model id, e.g.
#     "google/gemini-2.5-flash" (cheap, ~$0.30/$2.50 per MTok in/out vs.
#     claude-opus-4-8's $5/$25 - verified 2026-07, see llm/client.py's
#     COST_PER_MTOK_USD). Judge model (below) must also be an OpenRouter id
#     when this is set - the judge shares the same LLMClient/provider.
DEEPRESEARCH_LLM_PROVIDER=anthropic
AWS_REGION=us-east-1
OPENROUTER_API_KEY=

# --- Search backend ---
TAVILY_API_KEY=

# --- Langfuse OTel export (app -> Langfuse Cloud) ---
# Sign up free at https://cloud.langfuse.com, create a project, copy its
# public/secret keys below. No self-hosting required (docs/DESIGN.md §6).
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Run config overrides (optional) ---
DEEPRESEARCH_PLANNER_MODEL=claude-opus-4-8
DEEPRESEARCH_WORKER_MODEL=claude-opus-4-8
DEEPRESEARCH_REFLECTION_MODEL=claude-opus-4-8
DEEPRESEARCH_SYNTHESIS_MODEL=claude-opus-4-8
DEEPRESEARCH_SEARCH_BACKEND=tavily

# --- Rerank (docs/DESIGN.md row 7, docs/RESULTS.md for the ablation) ---
# on by default per the ablation; "bge" (self-hosted, default) or "cohere"
DEEPRESEARCH_RERANK_ENABLED=true
DEEPRESEARCH_RERANK_BACKEND=bge
DEEPRESEARCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# only needed if DEEPRESEARCH_RERANK_BACKEND=cohere
COHERE_API_KEY=

# --- Cache (docs/DESIGN.md row 8, docs/RESULTS.md for the measurement) ---
# on by default; set false for eval runs that must be cold (one-flag bypass)
DEEPRESEARCH_CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# --- Run store (docs/DESIGN.md row 9) ---
# defaults to a local SQLite file (the documented dev-loop swap) if unset;
# point at the docker-compose postgres service in deployed/CI:
# postgresql+asyncpg://deepresearch:deepresearch@postgres:5432/deepresearch
DATABASE_URL=sqlite+aiosqlite:///./deepresearch.db

# --- Judge (docs/DESIGN.md §5.5) ---
# cheap tier by default — grading doesn't need frontier capability. Must be
# a model id valid for whichever DEEPRESEARCH_LLM_PROVIDER is set above (e.g.
# "google/gemini-2.5-flash-lite" if provider=openrouter).
DEEPRESEARCH_JUDGE_MODEL=claude-haiku-4-5
