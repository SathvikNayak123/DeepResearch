# --- Agent LLM ---
ANTHROPIC_API_KEY=

# --- Search backend ---
TAVILY_API_KEY=

# --- Langfuse OTel export (app -> Langfuse) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Langfuse self-host secrets (generate each with: openssl rand -hex 32) ---
LANGFUSE_SALT=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_ENCRYPTION_KEY=

# --- Run config overrides (optional) ---
DEEPRESEARCH_PLANNER_MODEL=claude-opus-4-8
DEEPRESEARCH_WORKER_MODEL=claude-opus-4-8
DEEPRESEARCH_REFLECTION_MODEL=claude-opus-4-8
DEEPRESEARCH_SYNTHESIS_MODEL=claude-opus-4-8
DEEPRESEARCH_SEARCH_BACKEND=tavily

# --- Rerank (docs/DESIGN.md row 7, docs/RESULTS.md for the ablation) ---
# on by default per the ablation; "bge" (self-hosted, default) or "cohere"
DEEPRESEARCH_RERANK_ENABLED=true
DEEPRESEARCH_RERANK_BACKEND=bge
DEEPRESEARCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# only needed if DEEPRESEARCH_RERANK_BACKEND=cohere
COHERE_API_KEY=

# --- Cache (docs/DESIGN.md row 8, docs/RESULTS.md for the measurement) ---
# on by default; set false for eval runs that must be cold (one-flag bypass)
DEEPRESEARCH_CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# --- Run store (docs/DESIGN.md row 9) ---
# defaults to a local SQLite file (the documented dev-loop swap) if unset;
# point at the docker-compose postgres service in deployed/CI:
# postgresql+asyncpg://deepresearch:deepresearch@postgres:5432/deepresearch
DATABASE_URL=sqlite+aiosqlite:///./deepresearch.db

# --- Judge (docs/DESIGN.md §5.5) ---
# cheap tier by default — grading doesn't need frontier capability
DEEPRESEARCH_JUDGE_MODEL=claude-haiku-4-5
