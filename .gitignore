__pycache__/
*.pyc
.env
.venv/
venv/
*.egg-info/
.pytest_cache/
trajectories/*.json
!trajectories/.gitkeep
*.db
*.db-journal
# LangGraph AsyncSqliteSaver checkpoint files (config.checkpoint_db_path,
# default ./checkpoints.sqlite) — a separate persistence store from the
# eval/run-store *.db files above, same reason to never commit it.
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
# Transient run/benchmark console logs captured at the repo root (e.g.
# full_run_frames.log, directml_smoke_musique.log) — the durable record is
# the run-store DB + results/*.json, never these raw stdout dumps.
*.log

# data/corpus/ is normally regenerated on demand from HF Hub + Wikipedia
# (eval/benchmarks/{frames,musique}.py), but the smoke/full subset actually
# used by CI (n=20/n=100, seed 42) is committed below as a frozen snapshot
# — GitHub Actions runners hit Wikipedia's edge WAF (403s) reliably enough
# to make live ingestion unusable in CI, matching this project's own stated
# reason for LocalCorpusBackend existing ("no live-web flakiness ... in
# CI", docs/DESIGN.md §5.1) — see docs/RESULTS.md for the incident.
data/corpus/*
!data/corpus/frames/
!data/corpus/frames/*.json
!data/corpus/musique/
!data/corpus/musique/*.json

# Claude Code local tooling config/skills — not part of the project deliverable,
# and settings.local.json specifically is meant to be per-machine, not shared.
.claude/

# Reranker ONNX export/weight cache (rerank/bge_directml.py builds this on
# first run) — a large regenerable model artifact, never a source deliverable.
.cache/

# results/ holds per-run eval outputs (config-next-to-result), written on
# every eval invocation — kept out of the repo. The two exceptions are the
# CI gate's committed inputs: ci_baseline.json (what pr-smoke compares
# against, refreshed by nightly) and ci_gate_comment.md (the gate's rendered
# comment). Everything else here is a local/dev evidence artifact.
results/*
!results/ci_baseline.json
!results/ci_gate_comment.md

# Terraform: state/plan binaries and real secrets never belong in git.
# docs/proof/plan.txt is a redacted *text* export, committed deliberately.
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars
infra/tfplan
infra/*.tfplan
